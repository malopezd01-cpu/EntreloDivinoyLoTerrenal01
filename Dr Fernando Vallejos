<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Entre lo Divino y lo Terrenal</title>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/turn.js/4.1.0/turn.min.js"></script>

<style>
body{
margin:0;
background:#111;
display:flex;
justify-content:center;
align-items:center;
height:100vh;
}

#flipbook{
width:900px;
height:600px;
}

#flipbook img{
width:100%;
height:100%;
}
</style>
</head>

<body>

<div id="flipbook"></div>

<script>

let flipbook = document.getElementById("flipbook");

for(let i=1;i<=113;i++){

let num=i.toString().padStart(2,'0');

let img=document.createElement("img");

img.src="LIBRO-"+num+".png";

flipbook.appendChild(img);

}

$("#flipbook").turn({
width:900,
height:600,
autoCenter:true
});

</script>

</body>
</html>
